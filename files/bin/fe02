#!/bin/bash
# fe02: Fe02-OS Variant Switcher

REGISTRY="ghcr.io/m-fe02/fe02-os"

function show_usage() {
    echo "Fe02-OS Switcher"
    echo "Usage: fe02 [variant | command]"
    echo ""
    echo "Variants:"
    echo "  cosmic        -> :cosmic"
    echo "  cosmic-gaming -> :cosmic-gaming"
    echo "  gnome         -> :gnome"
    echo "  gnome-gaming  -> :gnome-gaming"
    echo "  kde           -> :kde"
    echo "  kde-gaming    -> :kde-gaming"
    echo ""
    echo "Commands:"
    echo "  status  - Show current booted and staged images"
    echo "  upgrade - Upgrade to the latest version of the current image"
}

if [ -z "$1" ]; then
    show_usage
    exit 1
fi

case "$1" in
    status)
        bootc status | grep -E "Booted|Queued|Image:"
        exit 0
        ;;
    upgrade)
        echo "⬆️  Upgrading..."
        sudo bootc upgrade
        exit $?
        ;;
    cosmic)
        TAG="cosmic"
        ;;
    cosmic-gaming)
        TAG="cosmic-gaming"
        ;;
    gnome)
        TAG="gnome"
        ;;
    gnome-gaming)
        TAG="gnome-gaming"
        ;;
    kde)
        TAG="kde"
        ;;
    kde-gaming)
        TAG="kde-gaming"
        ;;
    *)
        echo "Error: Unknown variant or command '$1'"
        show_usage
        exit 1
        ;;
esac

FULL_IMAGE_PATH="${REGISTRY}:${TAG}"

echo "🔄 Preparing switch to Fe02-OS ($TAG)..."
sudo bootc switch --transport registry "${FULL_IMAGE_PATH}"

if [ $? -eq 0 ]; then
    echo -e "\n✅ Switch staged. Your branding hijacks will be active after reboot."
    read -p "Reboot now? (y/N): " confirm
    [[ $confirm == [yY] ]] && sudo reboot
else
    echo "❌ Switch failed. Check your network or GHCR access."
fi
